# ============================================================
# Agent Mail Bridge - 环境变量示例
# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，禁止提交。
# ============================================================

# --- Gmail 收件配置 ---
# 你自己的 Gmail 地址
GMAIL_ADDRESS=your_gmail@gmail.com
# Gmail 应用专用密码（16 位），不是普通邮箱密码
# 详见：https://myaccount.google.com/apppasswords
# 注意：仅 IMAP 后端需要；Gmail API 后端使用 OAuth，不需要此密码
GMAIL_APP_PASSWORD=your_16_digit_app_password
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993

# --- Gmail 收件后端切换 ---
# imap      = 通过 IMAP 993 收件（需应用专用密码 + IMAP 端口可达）
# gmail_api = 通过 Gmail API over HTTPS 443 收件（需 OAuth credentials.json/token.json）
# auto      = 优先 gmail_api（已配置 credentials.json），否则回退 imap
GMAIL_RECEIVE_BACKEND=gmail_api

# Gmail API OAuth 文件（相对路径基于项目根目录）
GMAIL_API_CREDENTIALS_PATH=secrets/credentials.json
GMAIL_API_TOKEN_PATH=secrets/token.json
# Gmail API scope（默认只读：读取邮件与附件，不能发/删/标记）
GMAIL_API_SCOPES=https://www.googleapis.com/auth/gmail.readonly
# Gmail API 查询设置
GMAIL_API_MAX_RESULTS=20
GMAIL_API_QUERY=in:inbox

# --- Gmail 网络适配层 ---
# direct = 直连 Gmail（国外用户 / 全局 TUN/VPN 已接管流量）
# socks5 = 通过本地 SOCKS5 代理连接（v2rayN / Clash Verge / sing-box / NekoRay）
# auto   = 先尝试 direct，失败后再尝试 socks5（推荐新手）
GMAIL_NETWORK_MODE=auto
# Gmail 连接超时（秒）
GMAIL_CONNECT_TIMEOUT=20
# SOCKS5 代理设置
# v2rayN 常见 SOCKS5 端口：127.0.0.1:10808
# Clash Verge 可能是 mixed-port / socks-port，需查看客户端设置
GMAIL_SOCKS5_HOST=127.0.0.1
GMAIL_SOCKS5_PORT=10808
# 是否由代理端解析域名（remote DNS），建议 true 以避免本机 DNS 污染
GMAIL_SOCKS5_REMOTE_DNS=true

# --- QQ 发件配置 ---
# 你的 QQ 邮箱地址，作为发件身份
QQ_EMAIL=your_qq@qq.com
# QQ 邮箱授权码，不是 QQ 登录密码
# 详见：QQ邮箱 -> 设置 -> 账户 -> POP3/IMAP/SMTP 开启后生成授权码
QQ_AUTH_CODE=your_qq_mail_auth_code
QQ_SMTP_HOST=smtp.qq.com
QQ_SMTP_PORT=465
# QQ SMTP 网络模式（对国内用户通常保持 direct 即可）
QQ_SMTP_NETWORK_MODE=direct
QQ_SMTP_CONNECT_TIMEOUT=20
# QQ SMTP SOCKS5 预留（本阶段未实现连接，仅预留配置键）
# QQ_SMTP_SOCKS5_HOST=127.0.0.1
# QQ_SMTP_SOCKS5_PORT=10808
# QQ_SMTP_SOCKS5_REMOTE_DNS=false

# --- 固定结果接收邮箱 ---
# 发件时收件人固定为该地址（应为用户 Gmail），不可随意改动
OWNER_GMAIL=your_gmail@gmail.com

# --- 本地数据目录 ---
# 相对路径基于项目根目录解析
DATA_ROOT=./AgentMailBridgeData
# 允许发送文件的额外目录，Windows 下多个目录使用分号分隔；留空时仅允许 DATA_ROOT
ALLOWED_SEND_ROOTS=

# --- 收件检测规则 ---
# 是否只收取 from=用户Gmail 且 to=用户Gmail 的自发自收邮件
AUTO_RECEIVE_ONLY_SELF_MAIL=true
# 单次最多抓取邮件数量
MAX_FETCH_LIMIT=30
# 是否只收未读邮件（true/false）
RECEIVE_UNSEEN_ONLY=false
# 收取后是否标记为已读（true/false）
RECEIVE_MARK_SEEN=false

# --- 附件大小限制，单位 MB ---
MAX_ATTACHMENT_MB=25
# --- 发送文件大小限制，单位 MB ---
MAX_SEND_FILE_MB=25

# --- 日志级别 ---
LOG_LEVEL=INFO
